@model BTTH_05.Models.MonHoc

@{
    ViewData["Title"] = "Thêm Lớp Học Mới";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-primary text-white p-3 rounded-top-4">
                    <h5 class="mb-0"><i class="fas fa-plus-circle me-2"></i>Thêm Lớp Học Mới</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        
                        @* Hàng 1: Mã định danh *@
                        <div class="row">
                            <div class="col-md-12 mb-3">
                                <label asp-for="MaMH" class="form-label fw-bold">Tên Lớp (Mã định danh)</label>
                                <input asp-for="MaMH" class="form-control rounded-3" placeholder="Ví dụ: Lập trình Web - Nhóm 01" />
                                <span asp-validation-for="MaMH" class="text-danger small"></span>
                                <div class="form-text text-muted">Lưu ý: Tên lớp này phải là duy nhất và không được trùng lặp.</div>
                            </div>
                        </div>

                        @* Hàng 2: Tên môn & Khoa *@
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="TenMH" class="form-label fw-bold">Tên Môn Học</label>
                                <input asp-for="TenMH" class="form-control rounded-3" placeholder="Ví dụ: Công nghệ phần mềm" />
                                <span asp-validation-for="TenMH" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Khoa" class="form-label fw-bold">Khoa</label>
                                <input asp-for="Khoa" class="form-control rounded-3" placeholder="Nhập tên khoa..." />
                                <span asp-validation-for="Khoa" class="text-danger small"></span>
                            </div>
                        </div>

                        @* Hàng 3: Tín chỉ, Học kỳ, Giảng viên *@
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label asp-for="SoTinChi" class="form-label fw-bold">Số tín chỉ</label>
                                <input asp-for="SoTinChi" class="form-control rounded-3" type="number" min="1" value="3" />
                                <span asp-validation-for="SoTinChi" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="HocKy" class="form-label fw-bold">Học kỳ</label>
                                <select asp-for="HocKy" class="form-select rounded-3">
                                    <option value="1">Học kỳ 1</option>
                                    <option value="2">Học kỳ 2</option>
                                    <option value="3">Học kỳ 3</option>
                                </select>
                                <span asp-validation-for="HocKy" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="MaGV" class="form-label fw-bold">Giảng viên hướng dẫn</label>
                                <input asp-for="MaGV" class="form-control rounded-3" placeholder="Nhập tên giảng viên..." />
                                <span asp-validation-for="MaGV" class="text-danger small"></span>
                            </div>
                        </div>

                        @* Hàng 4: Sĩ số hiện tại & Sĩ số tối đa *@
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="SiSoHienTai" class="form-label fw-bold">Sĩ số hiện tại</label>
                                <input asp-for="SiSoHienTai" class="form-control rounded-3 bg-light" type="number" min="0" value="0" />
                                <span asp-validation-for="SiSoHienTai" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="SiSoToiDa" class="form-label fw-bold">Sĩ số tối đa</label>
                                <input asp-for="SiSoToiDa" class="form-control rounded-3" type="number" min="1" value="60" />
                                <span asp-validation-for="SiSoToiDa" class="text-danger small"></span>
                            </div>
                        </div>

                        @* HÀNG MỚI: TRẠNG THÁI (Đã thêm theo ý Quân) *@
                        <div class="row">
                            <div class="col-md-12 mb-3">
                                <label asp-for="TrangThai" class="form-label fw-bold text-primary">Trạng thái lớp học</label>
                                <select asp-for="TrangThai" class="form-select rounded-3 border-primary shadow-sm">
                                    <option value="Đang mở" selected>Đang mở</option>
                                    <option value="Đã đóng">Đã đóng</option>
                                    <option value="Tạm hoãn">Tạm hoãn</option>
                                </select>
                                <span asp-validation-for="TrangThai" class="text-danger small"></span>
                            </div>
                        </div>

                        @* Nút bấm *@
                        <div class="d-flex gap-2 mt-4 pt-3 border-top">
                            <button type="submit" class="btn btn-primary px-4 rounded-pill shadow-sm">
                                <i class="fas fa-save me-1"></i> Lưu lớp học
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary px-4 rounded-pill">
                                <i class="fas fa-undo me-1"></i> Quay lại
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
