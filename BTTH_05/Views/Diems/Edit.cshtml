@model BTTH_05.Models.Student

@{
    ViewData["Title"] = "Chỉnh sửa lộ trình điểm - " + Model.HoTen;
}

<div class="container py-4">
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-header bg-primary text-white py-3">
            <h4 class="mb-0 fw-bold"><i class="fas fa-user-edit me-2"></i>CẬP NHẬT THÔNG TIN & ĐIỂM 4 NĂM</h4>
        </div>
        <div class="card-body p-4">
            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                
                @* Khóa chính ẩn *@
                <input type="hidden" asp-for="MaSV" />

                <div class="row">
                    @* --- PHẦN 1: THÔNG TIN SINH VIÊN --- *@
                    <div class="col-md-12 mb-4">
                        <h6 class="fw-bold text-primary border-bottom pb-2 text-uppercase">1. Thông tin cơ bản</h6>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Họ và tên</label>
                                <input asp-for="HoTen" class="form-control shadow-sm" placeholder="Nhập họ tên sinh viên" />
                                <span asp-validation-for="HoTen" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Lớp học</label>
                                <input asp-for="LopHoc" class="form-control" placeholder="Ví dụ: CNTT K18-01" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Năm thứ đang học</label>
                                <select asp-for="NamThu" id="selectNamThu" class="form-select border-warning shadow-sm">
                                    <option value="1">Năm 1</option>
                                    <option value="2">Năm 2</option>
                                    <option value="3">Năm 3</option>
                                    <option value="4">Năm 4</option>
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Trạng thái</label>
                                <select asp-for="TrangThai" class="form-select">
                                    <option value="Đang học">Đang học</option>
                                    <option value="Sắp tốt nghiệp">Sắp tốt nghiệp</option>
                                    <option value="Bảo lưu">Bảo lưu</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    @* --- PHẦN 2: LỘ TRÌNH ĐIỂM 4 NĂM --- *@
                    <div class="col-md-12">
                        <h6 class="fw-bold text-success border-bottom pb-2 text-uppercase">2. Điểm trung bình tích lũy (GPA)</h6>
                        <div class="row g-3">
                            <div class="col-md-3">
                                <div class="p-3 bg-light rounded-3 border" id="boxNam1">
                                    <label class="form-label fw-bold text-info small">GPA NĂM 1</label>
                                    <input asp-for="GpaNam1" class="form-control fw-bold score-input" type="number" step="0.01" min="0" max="10" />
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="p-3 bg-light rounded-3 border" id="boxNam2">
                                    <label class="form-label fw-bold text-warning small">GPA NĂM 2</label>
                                    <input asp-for="GpaNam2" class="form-control fw-bold score-input" type="number" step="0.01" min="0" max="10" />
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="p-3 bg-light rounded-3 border" id="boxNam3">
                                    <label class="form-label fw-bold text-success small">GPA NĂM 3</label>
                                    <input asp-for="GpaNam3" class="form-control fw-bold score-input" type="number" step="0.01" min="0" max="10" />
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="p-3 bg-light rounded-3 border" id="boxNam4">
                                    <label class="form-label fw-bold text-danger small">GPA NĂM 4</label>
                                    <input asp-for="GpaNam4" class="form-control fw-bold score-input" type="number" step="0.01" min="0" max="10" />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mt-5 border-top pt-4 text-center">
                    <button type="submit" class="btn btn-primary px-5 rounded-pill shadow-sm fw-bold btn-lg">
                        <i class="fas fa-save me-2"></i>CẬP NHẬT DỮ LIỆU
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary px-4 rounded-pill ms-2">
                        <i class="fas fa-times me-2"></i>Hủy bỏ
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const selectNamThu = document.getElementById("selectNamThu");
            const inputs = {
                2: document.getElementById("GpaNam2"),
                3: document.getElementById("GpaNam3"),
                4: document.getElementById("GpaNam4")
            };
            const boxes = {
                2: document.getElementById("boxNam2"),
                3: document.getElementById("boxNam3"),
                4: document.getElementById("boxNam4")
            };

            function updateInputState() {
                const namThu = parseInt(selectNamThu.value);
                
                for (let i = 2; i <= 4; i++) {
                    if (inputs[i] && boxes[i]) {
                        if (namThu < i) {
                            inputs[i].readOnly = true;
                            inputs[i].tabIndex = -1; 
                            boxes[i].classList.add("bg-disabled");
                            boxes[i].style.opacity = "0.6";
                        } else {
                            inputs[i].readOnly = false;
                            inputs[i].tabIndex = 0;
                            boxes[i].classList.remove("bg-disabled");
                            boxes[i].style.opacity = "1";
                        }
                    }
                }
            }

            updateInputState();
            selectNamThu.addEventListener("change", updateInputState);
        });
    </script>

    <style>
        .rounded-4 { border-radius: 1.25rem !important; }
        .score-input:focus { border-color: #003580; box-shadow: 0 0 0 0.25rem rgba(0, 53, 128, 0.1); }
        .bg-primary { background-color: #003580 !important; }
        .bg-disabled { background-color: #f1f3f5 !important; }
        .form-control:read-only { cursor: not-allowed; background-color: #e9ecef; }
    </style>
}
