@model BTTH_05.Models.Student
@{
    ViewData["Title"] = "Hồ sơ sinh viên - " + Model.HoTen;
    // Lấy GPA tổng kết từ thuộc tính mới hoặc tính toán
    var gpaTichLuy = Model.GpaTuNhap ?? 0;
}

<div class="container-fluid py-4 bg-light min-vh-100">
    @* --- Header điều hướng --- *@
    <div class="mb-4 d-flex justify-content-between align-items-center">
        <a asp-action="Index" class="btn btn-outline-primary rounded-pill px-3 shadow-sm bg-white">
            <i class="fas fa-arrow-left me-1"></i> Quay lại danh sách
        </a>
        <div class="text-end">
            <h5 class="mb-0 fw-bold text-dark text-uppercase">HỒ SƠ NĂNG LỰC SINH VIÊN</h5>
            <small class="text-muted">Trạng thái: <span class="badge bg-info text-white">@Model.TrangThai</span></small>
        </div>
    </div>

    <div class="row g-4">
        @* --- CỘT TRÁI: THÔNG TIN CÁ NHÂN --- *@
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
                @* Header Profile: Gradient đồng bộ DNU *@
                <div class="card-header border-0 py-4 text-center text-white" style="background: linear-gradient(135deg, #003580 0%, #ff8533 100%);">
                    <div class="avatar-circle mx-auto mb-3 fw-bold text-primary shadow-sm" 
                         style="background: white; width: 90px; height: 90px; font-size: 2.5rem; line-height: 90px; border-radius: 50%;">
                        @(string.IsNullOrEmpty(Model.HoTen) ? "?" : Model.HoTen.Trim().Split(' ').Last()[0].ToString().ToUpper())
                    </div>
                    <h4 class="fw-bold mb-1">@Model.HoTen</h4>
                    <span class="badge rounded-pill bg-white bg-opacity-25 border border-white border-opacity-50 px-3 py-2">
                        MSSV: @Model.MaSV
                    </span>
                </div>

                <div class="card-body p-4 bg-white">
                    <h6 class="text-primary fw-bold text-uppercase small mb-3 border-bottom pb-2">Thông tin học tập</h6>
                    
                    @* --- BỔ SUNG: NGÀNH HỌC --- *@
                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted small">Ngành học:</span>
                        <span class="fw-bold text-dark text-end ms-2">@(!string.IsNullOrEmpty(Model.NganhHoc) ? Model.NganhHoc : "Chưa cập nhật")</span>
                    </div>

                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted small">Chuyên ngành:</span>
                        <span class="fw-bold text-dark text-end ms-2">@(!string.IsNullOrEmpty(Model.TenCN_TuNhap) ? Model.TenCN_TuNhap : (Model.ChuyenNganh?.TenCN ?? "Công nghệ thông tin"))</span>
                    </div>
                    
                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted small">Lớp học:</span>
                        <span class="fw-bold text-primary">@(!string.IsNullOrEmpty(Model.LopHoc) ? Model.LopHoc : "N/A")</span>
                    </div>
                    
                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted small">Năm học:</span>
                        <span class="fw-bold text-dark">Năm thứ @(Model.NamThu ?? 1)</span>
                    </div>

                    <h6 class="text-primary fw-bold text-uppercase small mt-4 mb-3 border-bottom pb-2">Liên lạc & Cá nhân</h6>
                    <div class="mb-3">
                        <label class="text-muted small d-block">Email:</label>
                        <span class="fw-bold text-dark">@(!string.IsNullOrEmpty(Model.Email) ? Model.Email : "---")</span>
                    </div>
                    <div class="mb-3">
                        <label class="text-muted small d-block">Số điện thoại:</label>
                        <span class="fw-bold text-dark">@(!string.IsNullOrEmpty(Model.Sdt) ? Model.Sdt : "---")</span>
                    </div>

                    <div class="mt-4 pt-3 border-top d-grid gap-2">
                        <a asp-action="Edit" asp-route-id="@Model.MaSV" class="btn btn-warning rounded-pill fw-bold border-0 shadow-sm text-white" style="background-color: #ff8533;">
                            <i class="fas fa-edit me-1"></i> Chỉnh sửa hồ sơ
                        </a>
                    </div>
                </div>
            </div>

            @* Card Tổng kết GPA *@
            <div class="card border-0 shadow-sm rounded-4 text-white p-4 text-center" style="background-color: #003580;">
                <h6 class="text-uppercase small fw-bold opacity-75">GPA Tích Lũy Trung Bình</h6>
                <h1 class="display-4 fw-bold mb-0">@string.Format("{0:0.00}", gpaTichLuy)</h1>
                <p class="mb-0 mt-2 fw-bold text-white-50">
                    Xếp loại: @(gpaTichLuy >= 8.0 ? "Giỏi" : (gpaTichLuy >= 6.5 ? "Khá" : (gpaTichLuy >= 5.0 ? "Trung bình" : "Yếu")))
                </p>
            </div>
        </div>

        @* --- CỘT PHẢI: LỘ TRÌNH ĐIỂM 4 NĂM --- *@
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 bg-white p-4">
                <h5 class="fw-bold mb-4 text-dark text-uppercase">
                    <i class="fas fa-chart-bar text-warning me-2"></i>Điểm trung bình các năm học
                </h5>

                <div class="row g-4">
                    @* Khối Năm 1 *@
                    <div class="col-md-6">
                        <div class="p-4 rounded-4 border-start border-5 border-info bg-light">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="text-info fw-bold text-uppercase mb-1">Năm học thứ 1</h6>
                                    <p class="text-muted small mb-0">Học kỳ 1 & 2</p>
                                </div>
                                <h2 class="fw-bold mb-0 text-dark">@(Model.GpaNam1?.ToString("0.00") ?? "0.00")</h2>
                            </div>
                        </div>
                    </div>

                    @* Khối Năm 2 *@
                    <div class="col-md-6">
                        <div class="p-4 rounded-4 border-start border-5 @(Model.NamThu >= 2 ? "border-warning bg-light" : "border-secondary opacity-50 bg-white")">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="@(Model.NamThu >= 2 ? "text-warning" : "text-secondary") fw-bold text-uppercase mb-1">Năm học thứ 2</h6>
                                    <p class="text-muted small mb-0">@(Model.NamThu >= 2 ? "Học kỳ 3 & 4" : "Chưa học đến")</p>
                                </div>
                                <h2 class="fw-bold mb-0 text-dark">@(Model.GpaNam2?.ToString("0.00") ?? "0.00")</h2>
                            </div>
                        </div>
                    </div>

                    @* Khối Năm 3 *@
                    <div class="col-md-6">
                        <div class="p-4 rounded-4 border-start border-5 @(Model.NamThu >= 3 ? "border-success bg-light" : "border-secondary opacity-50 bg-white")">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="@(Model.NamThu >= 3 ? "text-success" : "text-secondary") fw-bold text-uppercase mb-1">Năm học thứ 3</h6>
                                    <p class="text-muted small mb-0">@(Model.NamThu >= 3 ? "Học kỳ 5 & 6" : "Chưa học đến")</p>
                                </div>
                                <h2 class="fw-bold mb-0 text-dark">@(Model.GpaNam3?.ToString("0.00") ?? "0.00")</h2>
                            </div>
                        </div>
                    </div>

                    @* Khối Năm 4 *@
                    <div class="col-md-6">
                        <div class="p-4 rounded-4 border-start border-5 @(Model.NamThu >= 4 ? "border-danger bg-light" : "border-secondary opacity-50 bg-white")">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="@(Model.NamThu >= 4 ? "text-danger" : "text-secondary") fw-bold text-uppercase mb-1">Năm học thứ 4</h6>
                                    <p class="text-muted small mb-0">@(Model.NamThu >= 4 ? "Học kỳ 7 & 8" : "Chưa học đến")</p>
                                </div>
                                <h2 class="fw-bold mb-0 text-dark">@(Model.GpaNam4?.ToString("0.00") ?? "0.00")</h2>
                            </div>
                        </div>
                    </div>
                </div>

                @* Tiến độ *@
                <div class="mt-5">
                    <h6 class="fw-bold text-muted small text-uppercase mb-3">Tiến độ hoàn thành chương trình</h6>
                    <div class="progress rounded-pill" style="height: 12px;">
                        @{
                            var progress = (Model.NamThu ?? 1) * 25;
                            if (progress > 100) progress = 100;
                            var color = progress <= 25 ? "bg-info" : (progress <= 50 ? "bg-warning" : (progress <= 75 ? "bg-success" : "bg-danger"));
                        }
                        <div class="progress-bar @color progress-bar-striped progress-bar-animated" role="progressbar" style="width: @progress%"></div>
                    </div>
                    <div class="d-flex justify-content-between mt-2">
                        <span class="small text-muted">Năm 1</span>
                        <span class="small fw-bold text-primary">Đã đi được @progress% chặng đường</span>
                        <span class="small text-muted">Tốt nghiệp</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .rounded-4 { border-radius: 1.25rem !important; }
    .avatar-circle { display: flex; align-items: center; justify-content: center; border: 4px solid rgba(255,255,255,0.2); }
    .card { border: none !important; }
    .border-5 { border-left-width: 5px !important; }
    .btn-outline-primary:hover { background-color: #003580; color: white; border-color: #003580; }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
