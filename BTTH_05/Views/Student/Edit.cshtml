@model BTTH_05.Models.Student
@{
    ViewData["Title"] = "Chỉnh Sửa Sinh Viên - DNU";
}

<div class="container py-4 bg-light min-vh-100">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-7">
            <div class="mb-3">
                <a asp-action="Index" class="btn btn-sm btn-white shadow-sm rounded-pill px-3 text-secondary fw-bold text-decoration-none">
                    <i class="fas fa-chevron-left me-1"></i>Quay lại
                </a>
            </div>

            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                @* Header: Gradient DNU đặc trưng *@
                <div class="card-header py-3 border-0" style="background: linear-gradient(135deg, #003580 0%, #ff8533 100%) !important;">
                    <h5 class="mb-0 text-center text-white text-uppercase fw-bold" style="letter-spacing: 1px;">
                        <i class="fas fa-user-edit me-2"></i>Cập Nhật Thông Tin
                    </h5>
                </div>
                
                <div class="card-body p-4 bg-white">
                    <form asp-action="Edit" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        @* Giữ key để update đúng dòng *@
                        <input type="hidden" asp-for="MaSV" />
                        <input type="hidden" asp-for="MaCN" />

                        <div class="row g-3">
                            @* --- HỌ TÊN & MSSV --- *@
                            <div class="col-md-8">
                                <label class="form-label small fw-bold text-dark ms-2">Họ và Tên</label>
                                <input asp-for="HoTen" class="form-control form-control-sm bg-light border-0 rounded-pill px-3" placeholder="Họ tên...">
                                <span asp-validation-for="HoTen" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small fw-bold text-dark ms-2">Mã SV</label>
                                <input asp-for="MaSV" class="form-control form-control-sm bg-white border rounded-pill px-3 fw-bold text-secondary" disabled />
                            </div>

                            @* --- GPA TÍCH LŨY --- *@
                            <div class="col-12">
                                <div class="p-3 rounded-4" style="background-color: rgba(0, 53, 128, 0.05); border: 1px solid #cce5ff;">
                                    <label class="form-label small fw-bold text-primary ms-2 mb-1">
                                        <i class="fas fa-star me-1"></i> GPA TÍCH LŨY TOÀN KHÓA (NHẬP TAY)
                                    </label>
                                    <input asp-for="GpaTuNhap" type="number" step="0.01" min="0" max="10" 
                                           class="form-control form-control-sm border-0 rounded-pill px-3 fw-bold text-primary shadow-sm" 
                                           placeholder="Nhập GPA hệ 10 hoặc hệ 4...">
                                    <small class="text-muted ms-2" style="font-size: 0.7rem;">* Điểm này sẽ ưu tiên hiển thị tại trang Sắp tốt nghiệp.</small>
                                </div>
                            </div>

                            @* --- MÔN HỌC ĐANG THEO HỌC --- *@
                            <div class="col-12">
                                <div class="p-2 rounded-4" style="background-color: #fffaf5; border: 1px dashed #ff8533;">
                                    <label class="form-label small fw-bold text-dark ms-2 mb-1">
                                        <i class="fas fa-book me-1 text-warning"></i> Môn Học Đang Theo Học
                                    </label>
                                    <input asp-for="TenMonHoc" class="form-control form-control-sm border-0 rounded-pill px-3 shadow-sm" 
                                           placeholder="Ví dụ: Lập trình .NET, Marketing...">
                                </div>
                            </div>

                            @* --- NGÀNH HỌC (MỚI THÊM) & LỚP HỌC --- *@
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-dark ms-2">Ngành Học</label>
                                <input asp-for="NganhHoc" class="form-control form-control-sm bg-light border-0 rounded-pill px-3" placeholder="Nhập ngành...">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-dark ms-2">Lớp Học</label>
                                <input asp-for="LopHoc" class="form-control form-control-sm bg-light border-0 rounded-pill px-3" placeholder="Ví dụ: LKT16-05...">
                            </div>

                            @* --- CHUYÊN NGÀNH GÕ TAY --- *@
                            <div class="col-12">
                                <label class="form-label small fw-bold text-dark ms-2">Chuyên Ngành Chi Tiết (Gõ tay)</label>
                                <input asp-for="TenCN_TuNhap" class="form-control form-control-sm bg-light border-0 rounded-pill px-3" placeholder="Ví dụ: Luật Doanh nghiệp, Business Analyst...">
                            </div>

                            @* --- EMAIL & SĐT --- *@
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-dark ms-2">Email</label>
                                <input asp-for="Email" type="email" class="form-control form-control-sm bg-light border-0 rounded-pill px-3" placeholder="email@dnu.edu.vn">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-dark ms-2">Số điện thoại</label>
                                <input asp-for="Sdt" class="form-control form-control-sm bg-light border-0 rounded-pill px-3" placeholder="09xxx...">
                            </div>

                            @* --- NGÀY SINH --- *@
                            <div class="col-md-4">
                                <label class="form-label small fw-bold text-dark ms-2">Ngày Sinh</label>
                                <input asp-for="NgaySinh" type="text" class="form-control form-control-sm bg-light border-0 rounded-pill px-3" placeholder="dd/MM/yyyy">
                                <span asp-validation-for="NgaySinh" class="text-danger small"></span>
                            </div>

                            @* --- SINH VIÊN NĂM THỨ --- *@
                            <div class="col-md-4">
                                <label class="form-label small fw-bold text-success ms-2">Sinh viên năm thứ</label>
                                <select asp-for="NamThu" class="form-select form-select-sm bg-light border-0 rounded-pill px-3">
                                    <option value="1">Năm thứ 1</option>
                                    <option value="2">Năm thứ 2</option>
                                    <option value="3">Năm thứ 3</option>
                                    <option value="4">Năm thứ 4</option>
                                    <option value="5">Năm thứ 5</option>
                                </select>
                            </div>

                            @* --- TRẠNG THÁI --- *@
                            <div class="col-md-4">
                                <label class="form-label small fw-bold text-dark ms-2">Trạng Thái</label>
                                <select asp-for="TrangThai" class="form-select form-select-sm bg-light border-0 rounded-pill px-3">
                                    <option value="Đang học">Đang học</option>
                                    <option value="Sắp tốt nghiệp">Sắp tốt nghiệp</option>
                                    <option value="Đã tốt nghiệp">Đã tốt nghiệp</option>
                                    <option value="Bảo lưu">Bảo lưu</option>
                                    <option value="Nghỉ học">Nghỉ học</option>
                                </select>
                            </div>
                        </div>

                        <div class="mt-4 d-flex gap-2">
                            @* Nút lưu: Gradient DNU hòa quyện *@
                            <button type="submit" class="btn btn-sm rounded-pill flex-grow-1 fw-bold shadow border-0 text-white" 
                                    style="background: linear-gradient(90deg, #ff8533 0%, #003580 100%) !important;">
                                <i class="fas fa-save me-1"></i> LƯU THAY ĐỔI
                            </button>
                            <a asp-action="Index" class="btn btn-light btn-sm rounded-pill px-4 border fw-bold text-muted">
                                HỦY
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    :root {
        --dnu-orange-soft: #ff8533;
        --dnu-blue: #003580;
    }
    .btn-white { background: #fff; border: 1px solid #dee2e6; }
    .form-control-sm, .form-select-sm { height: 40px; }
    .form-control:focus, .form-select:focus {
        background-color: #fff !important;
        box-shadow: 0 0 0 0.2rem rgba(255, 133, 51, 0.2);
        border: 1px solid var(--dnu-orange-soft) !important;
    }
    .card-header { border-bottom: 0; }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
