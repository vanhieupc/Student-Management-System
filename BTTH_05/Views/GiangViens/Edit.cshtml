@model BTTH_05.Models.GiangVien

@{
    ViewData["Title"] = "Chỉnh sửa giảng viên";
}

<div class="container py-4">
    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-header bg-warning text-dark p-3">
            <h4 class="mb-0"><i class="fas fa-user-edit me-2"></i>Chỉnh sửa giảng viên: @Model.HoTen</h4>
        </div>
        <div class="card-body p-4">
            <form asp-action="Edit" method="post"> @* Thêm method="post" cho chắc chắn *@
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                
                @* Dùng oldId để Controller biết bạn đang sửa bản ghi nào trong Database *@
                <input type="hidden" name="oldId" value="@Model.MaGV" />
                @* Phải có MaCN ẩn để không bị lỗi ModelState do thiếu dữ liệu kiểu int? *@
                <input type="hidden" asp-for="MaCN" /> 

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="MaGV" class="form-label fw-bold">Mã giảng viên</label>
                        <input asp-for="MaGV" class="form-control border-primary" />
                        <span asp-validation-for="MaGV" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="HoTen" class="form-label fw-bold">Họ và tên</label>
                        <input asp-for="HoTen" class="form-control" required />
                        <span asp-validation-for="HoTen" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label fw-bold">Email</label>
                        <input asp-for="Email" class="form-control" type="email" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="SoDienThoai" class="form-label fw-bold">Số điện thoại</label>
                        <input asp-for="SoDienThoai" class="form-control" />
                        <span asp-validation-for="SoDienThoai" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Khoa" class="form-label fw-bold">Khoa</label>
                        <input asp-for="Khoa" class="form-control" />
                        <span asp-validation-for="Khoa" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="ChucDanh" class="form-label fw-bold">Chức danh</label>
                        <input asp-for="ChucDanh" class="form-control" />
                        <span asp-validation-for="ChucDanh" class="text-danger"></span>
                    </div>

                    <div class="col-md-12">
                        <label asp-for="TrangThai" class="form-label fw-bold">Trạng thái</label>
                        <select asp-for="TrangThai" class="form-select border-primary">
                            <option value="Đang làm việc">Đang làm việc</option>
                            <option value="Nghỉ phép">Nghỉ phép</option>
                            <option value="Đã nghỉ việc">Đã nghỉ việc</option>
                        </select>
                        <span asp-validation-for="TrangThai" class="text-danger"></span>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary px-4 rounded-pill">
                        <i class="fas fa-save me-2"></i>Cập nhật
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary px-4 rounded-pill">
                        Quay lại
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
